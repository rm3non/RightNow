rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================
    // HELPER FUNCTIONS
    // ========================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isVerified() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verified == true;
    }

    // ========================
    // USERS
    // ========================
    match /users/{uid} {
      // Anyone authenticated can read user profiles (needed for feed, matches)
      allow read: if isAuthenticated();

      // Users can only create/update their own profile
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // No delete in MVP
      allow delete: if false;
    }

    // ========================
    // USER PHOTOS
    // ========================
    match /user_photos/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ========================
    // POSTS (Intents)
    // ========================
    match /posts/{postId} {
      // Only verified users can read posts
      // Safe users can only read posts marked 'safe'
      allow read: if isVerified() && (
        resource.data.user_content_mode == 'safe' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.content_mode == 'open_enabled'
      );

      // Users can create posts for themselves
      allow create: if isVerified()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.user_content_mode == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.content_mode;

      // Users can only update to expire their own posts
      allow update: if isAuthenticated()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'expired';

      allow delete: if false;
    }

    // ========================
    // INTERESTS
    // ========================
    match /interests/{interestId} {
      // Users can read interests they're involved in
      allow read: if isAuthenticated()
        && (resource.data.from_user == request.auth.uid
            || resource.data.to_user == request.auth.uid);

      // Users can create interests from themselves
      allow create: if isAuthenticated()
        && request.resource.data.from_user == request.auth.uid;

      allow update, delete: if false;
    }

    // ========================
    // MATCHES (Cloud Functions only create)
    // ========================
    match /matches/{matchId} {
      // Only participants can read
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Only Cloud Functions can create/update matches
      allow create, update: if false;

      allow delete: if false;
    }

    // ========================
    // CHATS
    // ========================
    match /chats/{chatId} {
      // Only participants can read
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Only Cloud Functions create chats
      allow create: if false;

      // Participants can ONLY update status to block the chat
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'blocked';

      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        // Participants can read messages
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // No direct write; messages created via Cloud Function
        allow create, update, delete: if false;
      }
    }

    // ========================
    // REPORTS
    // ========================
    match /reports/{reportId} {
      // Users can create reports
      allow create: if isAuthenticated()
        && request.resource.data.reporter_uid == request.auth.uid;

      // No read access for regular users
      allow read, update, delete: if false;
    }

    // ========================
    // BLOCKS
    // ========================
    match /blocks/{blockId} {
      // Users can read their own blocks
      allow read: if isAuthenticated()
        && (resource.data.blocker_uid == request.auth.uid
            || resource.data.blocked_uid == request.auth.uid);

      // Users can create blocks
      allow create: if isAuthenticated()
        && request.resource.data.blocker_uid == request.auth.uid;

      allow update, delete: if false;
    }
  }
}
